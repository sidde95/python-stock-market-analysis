{\n "cells": [\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "# 00 – Environment Setup & Data Download\n",\n    "\n",\n    "**Activity 1 Deliverable**\n",\n    "\n",\n    "This notebook verifies the environment, downloads OHLCV data for three tickers, and plots their closing prices.\n",\n    "\n",\n    "| Ticker | Role |\n",\n    "|--------|------|\n",\n    "| AAPL   | Mega-cap |\n",\n    "| NVDA   | High-beta |\n",\n    "| SPY    | ETF benchmark |"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "## 1 – Library Imports & Version Check"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "import importlib, sys\n",\n    "\n",\n    "required = [\n",\n    "    \"pandas\", \"numpy\", \"matplotlib\",\n",\n    "    \"yfinance\", \"stockstats\"\n",\n    "]\n",\n    "optional = [\"ta\", \"sklearn\"]\n",\n    "\n",\n    "print(f\"Python {sys.version}\n\")\n",\n    "print(\"=== Required packages ===\")\n",\n    "for pkg in required:\n",\n    "    try:\n",\n    "        mod = importlib.import_module(pkg)\n",\n    "        ver = getattr(mod, \"__version__\", \"(no __version__)\")\n",\n    "        print(f\"  ✓ {pkg:<14} {ver}\")\n",\n    "    except ImportError:\n",\n    "        print(f\"  ✗ {pkg:<14} NOT FOUND — run: pip install {pkg}\")\n",\n    "\n",\n    "print(\"\n=== Optional packages ===\")\n",\n    "for pkg in optional:\n",\n    "    try:\n",\n    "        mod = importlib.import_module(pkg)\n",\n    "        ver = getattr(mod, \"__version__\", \"(no __version__)\")\n",\n    "        print(f\"  ✓ {pkg:<14} {ver}\")\n",\n    "    except ImportError:\n",\n    "        print(f\"  - {pkg:<14} not installed (optional)\")"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "## 2 – Configuration"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "import pandas as pd\n",\n    "import numpy as np\n",\n    "import matplotlib.pyplot as plt\n",\n    "import matplotlib.dates as mdates\n",\n    "import yfinance as yf\n",\n    "\n",\n    "%matplotlib inline\n",\n    "plt.rcParams.update({\n",\n    "    \"figure.figsize\": (14, 5),\n",\n    "    \"axes.grid\": True,\n",\n    "    \"grid.linestyle\": \"--\",\n",\n    "    \"grid.alpha\": 0.5,\n",\n    "    \"font.size\": 11,\n",\n    "})\n",\n    "\n",\n    "# ── Tickers & date range ───────────────────────────────────────────────────────\n",\n    "TICKERS    = [\"AAPL\", \"NVDA\", \"SPY\"]   # mega-cap | high-beta | ETF benchmark\n",\n    "START_DATE = \"2023-01-01\"\n",\n    "END_DATE   = \"2026-03-26\"              # today\n",\n    "\n",\n    "print(f\"Tickers : {TICKERS}\")\n",\n    "print(f\"Period  : {START_DATE}  →  {END_DATE}\")"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "## 3 – Download OHLCV Data"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "raw = yf.download(\n",\n    "    tickers=TICKERS,\n",\n    "    start=START_DATE,\n",\n    "    end=END_DATE,\n",\n    "    auto_adjust=True,   # adjusts for splits & dividends\n",\n    "    progress=True,\n",\n    ")\n",\n    "\n",\n    "print(\"\nDataFrame shape :\", raw.shape)\n",\n    "print(\"Columns         :\", raw.columns.tolist()[:8], \"...\")\n",\n    "raw.tail(3)"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "## 4 – Extract Per-Ticker DataFrames"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "def get_ohlcv(ticker: str) -> pd.DataFrame:\n",\n    "    \"\"\"Slice OHLCV columns for a single ticker from the multi-level DataFrame.\"\"\"\n",\n    "    df = raw.xs(ticker, axis=1, level=1).copy()\n",\n    "    df.columns = df.columns.str.lower()  # Open, High, Low, Close, Volume → lower\n",\n    "    df.index.name = \"date\"\n",\n    "    df.dropna(inplace=True)\n",\n    "    return df\n",\n    "\n",\n    "data = {ticker: get_ohlcv(ticker) for ticker in TICKERS}\n",\n    "\n",\n    "# Quick sanity check\n",\n    "for t, df in data.items():\n",\n    "    print(f\"{t:6s}  rows={len(df):,}  \"\n",\n    "          f\"close_min={df[\"close\"].min():.2f}  \"\n",\n    "          f\"close_max={df[\"close\"].max():.2f}\")"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "## 5 – OHLCV Sample"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "print(\"── AAPL (last 5 rows) ──\")\n",\n    "display(data[\"AAPL\"].tail())\n",\n    "\n",\n    "print(\"\n── NVDA (last 5 rows) ──\")\n",\n    "display(data[\"NVDA\"].tail())\n",\n    "\n",\n    "print(\"\n── SPY (last 5 rows) ──\")\n",\n    "display(data[\"SPY\"].tail())"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "## 6 – Plot: Individual Close Prices"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "colors = {\"AAPL\": \"#1f77b4\", \"NVDA\": \"#2ca02c\", \"SPY\": \"#ff7f0e\"}\n",\n    "\n",\n    "fig, axes = plt.subplots(3, 1, figsize=(14, 12), sharex=True)\n",\n    "\n",\n    "for ax, ticker in zip(axes, TICKERS):\n",\n    "    df = data[ticker]\n",\n    "    ax.plot(df.index, df[\"close\"], color=colors[ticker], linewidth=1.4, label=ticker)\n",\n    "    ax.fill_between(df.index, df[\"close\"], alpha=0.08, color=colors[ticker])\n",\n    "    ax.set_ylabel(\"Close (USD)\", fontsize=10)\n",\n    "    ax.set_title(f\"{ticker} — Adjusted Close Price\", fontweight=\"bold\")\n",\n    "    ax.legend(loc=\"upper left\")\n",\n    "    ax.xaxis.set_major_formatter(mdates.DateFormatter(\"%b '%y\"))\n",\n    "\n",\n    "fig.suptitle(\"OHLCV Download Verification — Individual Close Prices\",\n",\n    "             fontsize=14, fontweight=\"bold\", y=1.01)\n",\n    "plt.tight_layout()\n",\n    "plt.savefig(\"individual_close.png\", dpi=120, bbox_inches=\"tight\")\n",\n    "plt.show()\n",\n    "print(\"Saved → individual_close.png\")"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "## 7 – Plot: Normalised Close Prices (Base = 100)"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "fig, ax = plt.subplots(figsize=(14, 5))\n",\n    "\n",\n    "for ticker in TICKERS:\n",\n    "    close = data[ticker][\"close\"]\n",\n    "    normalised = close / close.iloc[0] * 100\n",\n    "    ax.plot(normalised.index, normalised, label=ticker,\n",\n    "            color=colors[ticker], linewidth=1.6)\n",\n    "\n",\n    "ax.axhline(100, color=\"grey\", linewidth=0.8, linestyle=\"--\")\n",\n    "ax.set_title(\"Normalised Close Price (Base = 100 at start)\",\n",\n    "             fontweight=\"bold\")\n",\n    "ax.set_ylabel(\"Indexed Price\")\n",\n    "ax.xaxis.set_major_formatter(mdates.DateFormatter(\"%b '%y\"))\n",\n    "ax.legend()\n",\n    "plt.tight_layout()\n",\n    "plt.savefig(\"normalised_close.png\", dpi=120, bbox_inches=\"tight\")\n",\n    "plt.show()\n",\n    "print(\"Saved → normalised_close.png\")"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "## 8 – Plot: Volume Bars"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "fig, axes = plt.subplots(3, 1, figsize=(14, 9), sharex=True)\n",\n    "\n",\n    "for ax, ticker in zip(axes, TICKERS):\n",\n    "    df = data[ticker]\n",\n    "    ax.bar(df.index, df[\"volume\"] / 1e6, color=colors[ticker], alpha=0.6, width=1)\n",\n    "    ax.set_ylabel(\"Volume (M)\", fontsize=10)\n",\n    "    ax.set_title(f\"{ticker} — Daily Volume\", fontweight=\"bold\")\n",\n    "    ax.xaxis.set_major_formatter(mdates.DateFormatter(\"%b '%y\"))\n",\n    "\n",\n    "fig.suptitle(\"Daily Trading Volume\", fontsize=14, fontweight=\"bold\", y=1.01)\n",\n    "plt.tight_layout()\n",\n    "plt.savefig(\"volume_bars.png\", dpi=120, bbox_inches=\"tight\")\n",\n    "plt.show()\n",\n    "print(\"Saved → volume_bars.png\")"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "## 9 – Basic Descriptive Statistics"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,   \n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "stats_rows = []\n",\n    "for ticker in TICKERS:\n",\n    "    close = data[ticker][\"close\"]\n",\n    "    daily_ret = close.pct_change().dropna()\n",\n    "    stats_rows.append({\n",\n    "        \"ticker\"       : ticker,\n",\n    "        \"start\"        : close.index[0].date(),\n",\n    "        \"end\"          : close.index[-1].date(),\n",\n    "        \"trading_days\" : len(close),\n",\n    "        \"close_latest\" : round(close.iloc[-1], 2),\n",\n    "        \"total_return\" : f\"{(close.iloc[-1]/close.iloc[0]-1)*100:.1f}%\",\n",\n    "        \"ann_vol\"      : f\"{daily_ret.std()*np.sqrt(252)*100:.1f}%\",\n",\n    "        \"max_drawdown\" : f\"{((close/close.cummax())-1).min()*100:.1f}%\",\n",\n    "    })\n",\n    "\n",\n    "stats_df = pd.DataFrame(stats_rows).set_index(\"ticker\")\n",\n    "display(stats_df)"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "## 10 – Save OHLCV to CSV"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "import os\n",\n    "os.makedirs(\"data\", exist_ok=True)\n",\n    "\n",\n    "for ticker, df in data.items():\n",\n    "    path = f\"data/{ticker}_ohlcv.csv\"\n",\n    "    df.to_csv(path)\n",\n    "    print(f\"Saved → {path}  ({len(df):,} rows)\")\n",\n    "\n",\n    "print(\"\n✓ All OHLCV files written to data/\")"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "metadata": {},\n   "source": [\n    "---\n",\n    "### ✅ Activity 1 Checklist\n",\n    "\n",\n    "| Item | Status |\n",\n    "|------|--------|\n",\n    "| Environment created (conda / venv) | ☐ |\n",\n    "| pandas, numpy, matplotlib installed | ✓ (verified in cell 1) |\n",\n    "| yfinance installed | ✓ (verified in cell 1) |\n",\n    "| stockstats installed | ✓ (verified in cell 1) |\n",\n    "| Mega-cap ticker (AAPL) | ✓ |\n",\n    "| High-beta ticker (NVDA) | ✓ |\n",\n    "| ETF benchmark (SPY) | ✓ |\n",\n    "| OHLCV data downloaded | ✓ (cell 3) |\n",\n    "| Close price plotted | ✓ (cells 6–7) |\n",\n    "| CSVs saved to data/ | ✓ (cell 10) |"\n   ]\n }\n],\n "metadata": {\n  "kernelspec": {\n   "display_name": "Python 3",\n   "language": "python",\n   "name": "python3"\n  },\n  "language_info": {\n   "name": "python",\n   "version": "3.11.0"\n  }\n },\n "nbformat": 4,\n "nbformat_minor": 5\n}